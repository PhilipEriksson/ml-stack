#!/usr/bin/env bash

set -e

RUN=$1
shift || true

# Parse optional --sample flag
EXTRA_FLAGS=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --sample)
      EXTRA_FLAGS="--sample"
      shift
      ;;
    *)
      shift
      ;;
  esac
done

ROOT="${ML_STACK_HOME:-$HOME/ml-stack}"
CONFIG="$ROOT/outputs/runs/$RUN/config.json"

if [ -z "$RUN" ]; then
  echo "Usage: execute-training-run <run-name> [--sample]"
  echo ""
  echo "  --sample  Fast test mode: 1 epoch, batch=8, sparse logging"
  echo "             Auto-enabled for datasets with fewer than 10K examples"
  exit 1
fi

if [ ! -f "$CONFIG" ]; then
  echo "❌ Config not found: $CONFIG"
  echo "   Run 'create-training-run $RUN <model> <dataset>' first."
  exit 1
fi

# Resolve active training environment
TRAINING_ENV=$("$ROOT/scripts/utils/get-training-env")
CONDA_PYTHON=$("$ROOT/scripts/utils/get-training-env" --python || true)

if [ -z "$CONDA_PYTHON" ] || [ ! -f "$CONDA_PYTHON" ]; then
  echo "⚠️  Active training env '$TRAINING_ENV' not found. Falling back to 'training' env..."
  for CONDA_ROOT in "$HOME/miniconda" "$HOME/anaconda3" "$HOME/conda"; do
    if [ -f "$CONDA_ROOT/envs/training/bin/python" ]; then
      CONDA_PYTHON="$CONDA_ROOT/envs/training/bin/python"
      TRAINING_ENV="training"
      break
    fi
  done
fi

if [ -z "$CONDA_PYTHON" ] || [ ! -f "$CONDA_PYTHON" ]; then
  echo "❌ No training environment found (looked for '$TRAINING_ENV', then 'training')"
  echo "   Create one: conda env create -f envs/training.yml"
  exit 1
fi

# Auto-detect small datasets and enable fast settings
if [ -z "$EXTRA_FLAGS" ]; then
  DATASET_PATH=$("$CONDA_PYTHON" -c "import json; print(json.load(open('$CONFIG'))['dataset_path'])" 2>/dev/null)
  if [ -n "$DATASET_PATH" ]; then
    NUM_SAMPLES=$("$CONDA_PYTHON" -c "
from datasets import load_from_disk
ds = load_from_disk('$DATASET_PATH/train')
print(len(ds))
" 2>/dev/null)
    if [ -n "$NUM_SAMPLES" ] && [ "$NUM_SAMPLES" -lt 10000 ] 2>/dev/null; then
      EXTRA_FLAGS="--sample"
      echo "⚡ Auto-detected small dataset ($NUM_SAMPLES examples), using fast settings"
    fi
  fi
fi

# Display mode
if [ -n "$EXTRA_FLAGS" ]; then
  echo "🚀 Executing training run (SAMPLE mode): $RUN"
else
  echo "🚀 Executing training run: $RUN"
fi
echo "📋 Config: $CONFIG"

$CONDA_PYTHON "$ROOT/scripts/train/finetune.py" "$CONFIG" $EXTRA_FLAGS
