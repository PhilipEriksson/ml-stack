# dflash_server defaults — RTX 5090 long-context agentic runtime
# Edits here are picked up by launch-dflash and serve-dflash scripts

# Output limits
DFLASH_DEFAULT_MAX_TOKENS=1024
DFLASH_PORT=8080

# Max context: 256K native (512K+ requires RoPE scaling)
DFLASH_MAX_CTX=262144

# DFlash drafter (main speculative decode)
DFLASH_DDTREE_BUDGET=22
DFLASH_FA_WINDOW=4096

# KVFlash (lookahead sparse attention — 32K pool for 40-100K workloads)
# On RTX 5090: ~9.1 GiB free VRAM holds 32K tokens at q8_0 (~3.2 GiB)
# Use "auto" for short-prompt-only serving (caps at 16K)
DFLASH_KVFLASH=32768
DFLASH_CACHE_TYPE=q8_0
DFLASH_KVFLASH_TAU=64

# PFlash (prefill compression — activates above --prefill-threshold)
DFLASH_PREFILL_COMPRESSION=auto
DFLASH_PREFILL_THRESHOLD=32000
DFLASH_PREFILL_KEEP_RATIO=0.05

# BSA (set via env, compiled into binary)
DFLASH_FP_USE_BSA=1
DFLASH_FP_ALPHA=0.70
