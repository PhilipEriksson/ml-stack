# =========================
# ML ARTIFACTS (ignore contents, keep dirs via .gitkeep)
# =========================

# Models — ignore all files, keep structure
models/**/*
!models/base/.gitkeep
!models/quantized/.gitkeep
!models/finetuned/.gitkeep

# Datasets — ignore all files, keep structure
datasets/**/*
!datasets/raw/.gitkeep
!datasets/processed/.gitkeep

# Outputs — ignore all files, keep structure
outputs/**/*
!outputs/evals/.gitkeep
!outputs/runs/.gitkeep

# Training runs and artifacts
runs/
artifacts/

# =========================
# RUNTIMES (external source + large build)
# =========================
runtimes/**/*
!runtimes/.gitkeep

# =========================
# LOCAL STATE
# =========================
.claude_env
.claude/
configs/llama/
configs/vllm/.active-vllm
configs/.active-training-env

# =========================
# REGISTRIES (local state)
# =========================
configs/models/registry.json
configs/datasets/registry.json
configs/runs/registry.json

# =========================
# PYTHON / ENV
# =========================
__pycache__/
*.pyc
.venv/
.env/

# =========================
# UNSLOTH
# =========================
unsloth_compiled_cache/**
!unsloth_compiled_cache/.gitkeep

# =========================
# SYSTEM
# =========================
.DS_Store
*.log
